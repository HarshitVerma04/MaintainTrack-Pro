<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.maintaintrack.controllers.MaintenanceController"
      spacing="16" styleClass="screen-root">

    <padding><Insets top="24" right="28" bottom="24" left="28"/></padding>

    <!-- HEADER -->
    <HBox alignment="CENTER_LEFT" spacing="12">
        <Label text="Maintenance Log" styleClass="screen-title"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="+ Log Maintenance" styleClass="btn-primary" onAction="#onAdd"/>
    </HBox>

    <!-- LOG FORM — shown at top when adding -->
    <VBox fx:id="formPanel" styleClass="form-panel" spacing="12"
          visible="false" managed="false">

        <Label text="Log Maintenance Job" styleClass="form-title"/>

        <GridPane hgap="16" vgap="10">

            <!-- Row 0: Equipment + Done On -->
            <Label text="Equipment *" GridPane.rowIndex="0" GridPane.columnIndex="0" styleClass="form-label"/>
            <ComboBox fx:id="fieldEquipment" GridPane.rowIndex="0" GridPane.columnIndex="1"
                      prefWidth="280"/>

            <Label text="Done On *" GridPane.rowIndex="0" GridPane.columnIndex="2" styleClass="form-label"/>
            <DatePicker fx:id="fieldDoneOn" GridPane.rowIndex="0" GridPane.columnIndex="3"
                        prefWidth="200"/>

            <!-- Row 1: Done By + Notes -->
            <Label text="Done By *" GridPane.rowIndex="1" GridPane.columnIndex="0" styleClass="form-label"/>
            <TextField fx:id="fieldDoneBy" promptText="e.g. Harshit"
                       GridPane.rowIndex="1" GridPane.columnIndex="1" prefWidth="280"/>

            <Label text="Notes" GridPane.rowIndex="1" GridPane.columnIndex="2" styleClass="form-label"/>
            <TextField fx:id="fieldNotes" promptText="e.g. Oil changed, belt checked"
                       GridPane.rowIndex="1" GridPane.columnIndex="3" prefWidth="200"/>

        </GridPane>

        <!-- Next due preview -->
        <HBox alignment="CENTER_LEFT" spacing="8">
            <Label text="Next due will be:" styleClass="form-label"/>
            <Label fx:id="nextDuePreview" text="—" styleClass="form-label"
                   style="-fx-font-weight: bold; -fx-text-fill: #1a7a4a;"/>
        </HBox>

        <HBox spacing="10">
            <Button text="Save" styleClass="btn-primary" onAction="#onSave"/>
            <Button text="Cancel" styleClass="btn-secondary" onAction="#onCancel"/>
        </HBox>

        <Label fx:id="errorLabel" styleClass="error-label" text="" wrapText="true"/>
    </VBox>

    <!-- TABLE -->
    <TableView fx:id="logTable" VBox.vgrow="ALWAYS" styleClass="main-table">
        <columns>
            <TableColumn fx:id="colId"        text="ID"        prefWidth="50"/>
            <TableColumn fx:id="colEquipment" text="Equipment" prefWidth="220"/>
            <TableColumn fx:id="colDoneOn"    text="Done On"   prefWidth="130"/>
            <TableColumn fx:id="colDoneBy"    text="Done By"   prefWidth="140"/>
            <TableColumn fx:id="colNotes"     text="Notes"     prefWidth="360"/>
        </columns>
        <placeholder>
            <Label text="No maintenance logs yet. Click Log Maintenance to record a job."/>
        </placeholder>
    </TableView>

</VBox>
