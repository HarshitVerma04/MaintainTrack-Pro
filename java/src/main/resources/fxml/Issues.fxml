<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<HBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.maintaintrack.controllers.IssueController"
      spacing="16" styleClass="screen-root">

    <padding><Insets top="24" right="28" bottom="24" left="28"/></padding>

    <!-- LEFT: Form + table -->
    <VBox spacing="16" HBox.hgrow="ALWAYS">

        <!-- Header -->
        <HBox alignment="CENTER_LEFT" spacing="12">
            <Label text="Parts Issues and Work Orders" styleClass="screen-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="overdueBadge"  text="" styleClass="badge-danger" visible="false" managed="false"/>
            <Label fx:id="lowStockBadge" text="" styleClass="badge-danger" visible="false" managed="false"/>
            <Button text="+ Issue / Return Part" styleClass="btn-primary" onAction="#onAdd"/>
        </HBox>

        <!-- FORM -->
        <VBox fx:id="formPanel" styleClass="form-panel" spacing="12" visible="false" managed="false">

            <Label text="Record Part Transaction" styleClass="form-title"/>

            <HBox spacing="16" alignment="CENTER_LEFT">
                <Label text="Transaction:" styleClass="form-label"/>
                <RadioButton fx:id="radioIssue"  text="Issue (out)"   selected="true"/>
                <RadioButton fx:id="radioReturn" text="Return (back)"/>
            </HBox>

            <GridPane hgap="16" vgap="10">

                <Label text="Part *" GridPane.rowIndex="0" GridPane.columnIndex="0" styleClass="form-label"/>
                <ComboBox fx:id="fieldPart" GridPane.rowIndex="0" GridPane.columnIndex="1" prefWidth="260"/>
                <Label fx:id="stockPreview" text="--"
                       GridPane.rowIndex="0" GridPane.columnIndex="2"
                       GridPane.columnSpan="2" styleClass="form-label"/>

                <Label text="Equipment *" GridPane.rowIndex="1" GridPane.columnIndex="0" styleClass="form-label"/>
                <ComboBox fx:id="fieldEquipment" GridPane.rowIndex="1" GridPane.columnIndex="1" prefWidth="260"/>

                <Label text="Date *" GridPane.rowIndex="1" GridPane.columnIndex="2" styleClass="form-label"/>
                <DatePicker fx:id="fieldIssuedOn" GridPane.rowIndex="1" GridPane.columnIndex="3" prefWidth="180"/>

                <Label text="Qty *" GridPane.rowIndex="2" GridPane.columnIndex="0" styleClass="form-label"/>
                <TextField fx:id="fieldQty" promptText="e.g. 2"
                           GridPane.rowIndex="2" GridPane.columnIndex="1" prefWidth="260"/>

                <Label text="Issued By" GridPane.rowIndex="2" GridPane.columnIndex="2" styleClass="form-label"/>
                <TextField fx:id="fieldIssuedBy" promptText="e.g. Harshit"
                           GridPane.rowIndex="2" GridPane.columnIndex="3" prefWidth="180"/>

                <!-- Day 8: Breakdown link -->
                <Label text="Link to Breakdown" GridPane.rowIndex="3" GridPane.columnIndex="0" styleClass="form-label"/>
                <ComboBox fx:id="fieldBreakdown" GridPane.rowIndex="3" GridPane.columnIndex="1"
                          prefWidth="260" promptText="Optional"/>
                <Label text="Links to a repair work order"
                       GridPane.rowIndex="3" GridPane.columnIndex="2" GridPane.columnSpan="2"
                       style="-fx-text-fill:#5c6b8a; -fx-font-size:11px;"/>

                <!-- Day 9: Maintenance link -->
                <Label text="Link to PM Job" GridPane.rowIndex="4" GridPane.columnIndex="0" styleClass="form-label"/>
                <ComboBox fx:id="fieldMaintenance" GridPane.rowIndex="4" GridPane.columnIndex="1"
                          prefWidth="260" promptText="Optional"/>
                <Label text="Links to a scheduled maintenance job"
                       GridPane.rowIndex="4" GridPane.columnIndex="2" GridPane.columnSpan="2"
                       style="-fx-text-fill:#5c6b8a; -fx-font-size:11px;"/>

            </GridPane>

            <!-- Work order cost preview -->
            <HBox fx:id="workOrderCostBox" alignment="CENTER_LEFT" spacing="8"
                  visible="false" managed="false"
                  style="-fx-background-color:#d6e8fa; -fx-padding:8 12; -fx-background-radius:6;">
                <Label text="Work order cost so far:" style="-fx-font-weight:bold; -fx-text-fill:#1b3a6b;"/>
                <Label fx:id="workOrderCostLabel" text="Rs 0.00" style="-fx-font-weight:bold; -fx-text-fill:#1b3a6b;"/>
            </HBox>

            <HBox spacing="10">
                <Button text="Save"   styleClass="btn-primary"   onAction="#onSave"/>
                <Button text="Cancel" styleClass="btn-secondary" onAction="#onCancel"/>
            </HBox>

            <Label fx:id="errorLabel" styleClass="error-label" text="" wrapText="true"/>
        </VBox>

        <!-- TABLE -->
        <TableView fx:id="issueTable" VBox.vgrow="ALWAYS" styleClass="main-table">
            <columns>
                <TableColumn fx:id="colId"         text="ID"         prefWidth="45"/>
                <TableColumn fx:id="colPart"        text="Part"       prefWidth="170"/>
                <TableColumn fx:id="colEquipment"   text="Equipment"  prefWidth="150"/>
                <TableColumn fx:id="colIssuedOn"    text="Date"       prefWidth="105"/>
                <TableColumn fx:id="colQty"         text="Qty"        prefWidth="50"/>
                <TableColumn fx:id="colIssuedBy"    text="By"         prefWidth="90"/>
                <TableColumn fx:id="colType"        text="Type"       prefWidth="75"/>
                <TableColumn fx:id="colWorkOrder"   text="Work Order" prefWidth="190"/>
            </columns>
            <placeholder>
                <Label text="No transactions yet. Click Issue / Return Part to record one."/>
            </placeholder>
        </TableView>

    </VBox>

    <!-- RIGHT: Alert feed -->
    <VBox styleClass="dash-card" prefWidth="270" spacing="10">
        <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>
        <Label fx:id="alertCountLabel" text="Active Alerts" styleClass="card-title"/>
        <ListView fx:id="alertListView" VBox.vgrow="ALWAYS"/>
    </VBox>

</HBox>
