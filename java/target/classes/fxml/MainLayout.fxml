<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.maintaintrack.controllers.MainLayoutController"
            prefWidth="1100" prefHeight="720"
            styleClass="root-pane">

    <!-- ── SIDEBAR ─────────────────────────────────────────────────── -->
    <left>
        <VBox styleClass="sidebar" prefWidth="210" spacing="4">
            <padding><Insets top="24" right="12" bottom="24" left="12"/></padding>

            <!-- App title -->
            <Label text="MaintainTrack" styleClass="sidebar-title"/>
            <Label text="Pro" styleClass="sidebar-subtitle"/>

            <Separator styleClass="sidebar-sep"/>

            <!-- Nav buttons -->
            <Button fx:id="btnDashboard" text="📊  Dashboard"  styleClass="nav-btn" maxWidth="Infinity" onAction="#showDashboard"/>
            <Button fx:id="btnEquipment" text="⚙️  Equipment"  styleClass="nav-btn" maxWidth="Infinity" onAction="#showEquipment"/>
            <Button fx:id="btnParts"     text="🔩  Parts"       styleClass="nav-btn" maxWidth="Infinity" onAction="#showParts"/>
            <Button fx:id="btnSuppliers" text="🏭  Suppliers"   styleClass="nav-btn" maxWidth="Infinity" onAction="#showSuppliers"/>

            <Separator styleClass="sidebar-sep"/>

            <!-- Maintenance nav + overdue badge (Day 16) -->
            <HBox alignment="CENTER_LEFT" spacing="4" maxWidth="Infinity">
                <Button fx:id="btnMaintenance" text="🔧  Maintenance" styleClass="nav-btn"
                        HBox.hgrow="ALWAYS" onAction="#showMaintenance"/>
                <Label fx:id="sidebarOverdueBadge" styleClass="sidebar-alert-badge"
                       visible="false" managed="false"/>
            </HBox>

            <Button fx:id="btnBreakdown" text="⚠️  Breakdowns" styleClass="nav-btn" maxWidth="Infinity" onAction="#showBreakdown"/>

            <!-- Issues nav + low-stock badge (Day 16) -->
            <HBox alignment="CENTER_LEFT" spacing="4" maxWidth="Infinity">
                <Button fx:id="btnIssues" text="📦  Issues &amp; Alerts" styleClass="nav-btn"
                        HBox.hgrow="ALWAYS" onAction="#showIssues"/>
                <Label fx:id="sidebarLowStockBadge" styleClass="sidebar-alert-badge"
                       visible="false" managed="false"/>
            </HBox>

            <!-- Spacer pushes version to bottom -->
            <Region VBox.vgrow="ALWAYS"/>
            <Label text="v1.0.0" styleClass="sidebar-version"/>
        </VBox>
    </left>

    <!-- ── MAIN CONTENT AREA ────────────────────────────────────────── -->
    <center>
        <StackPane fx:id="contentArea" styleClass="content-area"/>
    </center>

</BorderPane>
